{
  "name": "@akari-os/sdk",
  "version": "0.1.0",
  "description": "AKARI OS App SDK — types + Phase 1 runtime (mcp / pool / models / chat-context / ui-hooks / partner)",
  "license": "MIT",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
