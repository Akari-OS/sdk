    "./memory": "./src/memory.ts",
    "./context": "./src/context.ts",
    "./ui": "./src/ui.ts",
    "./inter-app": "./src/inter-app.ts",
    "./permission": "./src/permission.ts",
    "./skill": "./src/skill.ts",
    "./panel-schema": "./src/panel-schema.ts",
    "./manifest": "./src/manifest.ts",
    "./errors": "./src/errors.ts",
    "./mcp": "./src/mcp.ts",
    "./pool": "./src/pool.ts",
    "./models": "./src/models.ts",
    "./model-store": "./src/model-store.ts",
    "./chat-context": "./src/chat-context.ts",
    "./ui-hooks": "./src/ui-hooks.ts",
    "./partner": "./src/partner.ts"
