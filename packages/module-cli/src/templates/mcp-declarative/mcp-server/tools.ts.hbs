/**
 * {{moduleName}} — MCP tool implementations
 * Spec: AKARI-HUB-024 §6.2 (MCP-Declarative Tier) + §6.6 (Memory API)
 *
 * Each function here corresponds to one MCP tool declared in:
 *   - akari.toml [mcp].tools
 *   - panel.schema.json actions[].mcp.tool
 *
 * Important:
 *   - Use @akari/sdk pool / amp APIs to persist data — never use local DB (HUB-024 §6.7 rule 2).
 *   - All amp.record() calls MUST include goal_ref (HUB-024 §6.6).
 *   - Prefer idempotent implementations (same input → same output).
 */

import { pool, amp, permission } from "@akari/sdk";

// ---------------------------------------------------------------------------
// Input / output types
// ---------------------------------------------------------------------------

export interface SampleActionInput {
  text: string;
  pool_ref?: string;
  scheduled_at?: string;
}

export interface SampleActionResult {
  content: Array<{ type: "text"; text: string }>;
  isError?: boolean;
}

// ---------------------------------------------------------------------------
// Tool: {{moduleSlug}}.sample_action
// ---------------------------------------------------------------------------

/**
 * Primary action for {{moduleName}}.
 * Replace this implementation with your module's actual logic.
 *
 * Contract (must be kept in sync with panel.schema.json + akari.toml):
 *   Input:  { text: string, pool_ref?: string, scheduled_at?: string }
 *   Output: MCP tool result (text content array)
 */
export async function sampleActionHandler(
  input: SampleActionInput
): Promise<SampleActionResult> {
  // 1. Permission gate — HITL is handled by Shell before calling this tool,
  //    but double-check write permissions programmatically (HUB-024 §6.6 Permission API).
  await permission.gate({
    action: "pool.write",
    reason: "Saving processed result to Pool",
    hitl: false,
  });

  // 2. Optionally fetch Pool item if a ref was provided
  let poolItemContent: string | undefined;
  if (input.pool_ref) {
    const poolItem = await pool.get(input.pool_ref);
    if (poolItem) {
      // Assume text-like pool items have a text property
      poolItemContent = String((poolItem as Record<string, unknown>).text ?? "");
    }
  }

  // 3. Process the input (replace with actual module logic)
  const result = [
    `Processed: ${input.text}`,
    poolItemContent ? `Pool context: ${poolItemContent}` : null,
    input.scheduled_at ? `Scheduled for: ${input.scheduled_at}` : null,
  ]
    .filter(Boolean)
    .join("\n");

  // 4. Persist the result back to Pool
  const savedId = await pool.put({
    bytes: Buffer.from(result),
    mime: "text/plain",
    tags: ["{{moduleSlug}}", "result"],
  });

  // 5. Record the action in AMP — goal_ref is REQUIRED (HUB-024 §6.6)
  await amp.record({
    kind: "action",
    content: `{{moduleName}} processed input (${input.text.slice(0, 50)}…)`,
    goal_ref: "{{moduleId}}",
    metadata: {
      pool_result_id: savedId,
      scheduled_at: input.scheduled_at,
    },
  });

  // 6. Return MCP tool result
  return {
    content: [
      {
        type: "text",
        text: result,
      },
    ],
  };
}
