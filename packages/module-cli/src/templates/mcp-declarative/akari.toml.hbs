# AKARI Module Manifest — spec AKARI-HUB-024 §6.5 + §6.2
# Generated by akari-module-cli (tier: mcp-declarative)

[module]
id      = "{{moduleId}}"
name    = "{{moduleName}}"
version = "0.1.0"
author  = "{{author}}"
tier    = "mcp-declarative"       # MCP-Declarative Tier: MCP server + panel.schema.json
sdk     = "{{sdkRange}}"          # Core SDK compatibility range (HUB-024 §6.5)

[mcp]
# Path to the bundled MCP server (relative to this manifest).
# May also be a remote URL (note: remote MCP makes the module network-dependent — see HUB-024 Q-10).
server = "mcp-server"
# Declare tools this server exposes. Used by Shell + Certification to validate MCP contract.
tools  = [
  "{{moduleSlug}}.sample_action",
]

[panels]
# panel.schema.json path relative to this manifest (HUB-025 §6.1)
main = { title = "{{moduleName}}", schema = "panel.schema.json" }

[permissions]
# Default deny — declare only what this module actually needs (HUB-024 §6.7 rule 5)
pool             = ["read", "write"]
amp              = ["read", "write"]
external-network = false
# oauth          = []   # Uncomment for OAuth-based services
