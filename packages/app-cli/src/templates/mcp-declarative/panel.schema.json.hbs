{
  "$schema": "akari://panel-schema/v0",
  "title": "{{t:app.title}}",
  "layout": "form",

  "fields": [
    {
      "id": "input_text",
      "type": "textarea",
      "label": "{{t:field.input_text}}",
      "placeholder": "{{t:field.input_text_placeholder}}",
      "bind": "mcp.{{appSlug}}.sample_action.text",
      "required": true,
      "maxLength": 1000,
      "helperText": "{{t:field.input_text_helper}}"
    },
    {
      "id": "pool_ref",
      "type": "pool-picker",
      "label": "{{t:field.pool_ref}}",
      "accept": ["text", "image", "document"],
      "max": 1,
      "bind": "state.pool_ref",
      "helperText": "{{t:field.pool_ref_helper}}"
    },
    {
      "id": "scheduled_at",
      "type": "datetime-optional",
      "label": "{{t:field.scheduled_at}}",
      "bind": "state.scheduled_at"
    }
  ],

  "actions": [
    {
      "id": "run_action",
      "label": "{{t:action.run}}",
      "kind": "primary",
      "mcp": {
        "tool": "{{appSlug}}.sample_action",
        "args": {
          "text": "$input_text",
          "pool_ref": "$pool_ref",
          "scheduled_at": "$scheduled_at"
        }
      },
      "hitl": {
        "require": true,
        "preview": "text-summary"
      },
      "enabled_when": "$input_text != null",
      "on_success": { "toast": "{{t:toast.success}}" },
      "on_error": { "toast": "{{t:toast.error}}: {{error}}" }
    }
  ],

  "locales": {
    "ja": {
      "app.title": "{{appName}}",
      "field.input_text": "入力テキスト",
      "field.input_text_placeholder": "テキストを入力…",
      "field.input_text_helper": "処理するテキストを入力してください",
      "field.pool_ref": "Pool 素材（任意）",
      "field.pool_ref_helper": "Pool から素材を選択して処理に含めることができます",
      "field.scheduled_at": "実行日時（任意）",
      "action.run": "実行",
      "toast.success": "処理が完了しました",
      "toast.error": "処理に失敗しました"
    },
    "en": {
      "app.title": "{{appName}}",
      "field.input_text": "Input Text",
      "field.input_text_placeholder": "Enter text…",
      "field.input_text_helper": "Enter the text to process",
      "field.pool_ref": "Pool Item (optional)",
      "field.pool_ref_helper": "Optionally select a Pool item to include in processing",
      "field.scheduled_at": "Schedule (optional)",
      "action.run": "Run",
      "toast.success": "Action completed",
      "toast.error": "Action failed"
    }
  }
}
