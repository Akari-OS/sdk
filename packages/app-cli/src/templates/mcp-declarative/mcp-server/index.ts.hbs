/**
 * {{appName}} — MCP Server entry point (MCP-Declarative Tier)
 * App ID: {{appId}}
 * Spec: AKARI-HUB-024 §6.2 (MCP-Declarative Tier)
 *
 * This file implements the MCP server that backs this app's panel.schema.json.
 * All tools declared in akari.toml [mcp].tools must be implemented here.
 *
 * Guidelines (HUB-024 §6.7):
 *   - Do NOT access the filesystem outside of what permissions allow.
 *   - Do NOT store state here — write to Pool / AMP via @akari/sdk.
 *   - Tools should be idempotent when possible (Skill API recommendation).
 */

import { McpServer } from "@modelcontextprotocol/sdk/server/mcp.js";
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";
import { z } from "zod";
import { sampleActionHandler } from "./tools.js";

// ---------------------------------------------------------------------------
// Server definition
// ---------------------------------------------------------------------------

const server = new McpServer({
  name: "{{appId}}",
  version: "0.1.0",
});

// ---------------------------------------------------------------------------
// Tool registration
// Register all tools declared in akari.toml [mcp].tools here.
// Tool names MUST match the declarations in akari.toml and panel.schema.json bindings.
// Naming follows ADR-009: <app-short-id>_<action> (snake_case).
// ---------------------------------------------------------------------------

server.tool(
  "{{appSlug}}.sample_action",
  "Sample action — replace with your app's primary action",
  {
    text: z
      .string()
      .max(1000)
      .describe("Input text to process (bound to panel field: input_text)"),
    pool_ref: z
      .string()
      .optional()
      .describe("Pool item ID (bound to panel field: pool_ref)"),
    scheduled_at: z
      .string()
      .datetime()
      .optional()
      .describe("ISO 8601 datetime for deferred execution (bound to panel field: scheduled_at)"),
  },
  async (args) => {
    return sampleActionHandler(args);
  }
);

// ---------------------------------------------------------------------------
// Transport + startup
// ---------------------------------------------------------------------------

async function main(): Promise<void> {
  const transport = new StdioServerTransport();
  await server.connect(transport);
  // MCP server is now listening on stdio — Shell will connect to this process.
}

main().catch((err) => {
  process.stderr.write(`Fatal: ${String(err)}\n`);
  process.exit(1);
});
