# AKARI App Manifest — spec AKARI-HUB-024 §6.5
# Generated by akari-app-cli (tier: full)

[app]
id      = "{{appId}}"
name    = "{{appName}}"
version = "0.1.0"
author  = "{{author}}"
tier    = "full"                  # Full Tier: React/Rust panel + agents + skills
sdk     = "{{sdkRange}}"          # Core SDK compatibility range (HUB-024 §6.5)

[permissions]
# Default deny — declare only what this app actually needs (HUB-024 §6.7 rule 5)
pool              = ["read", "write"]
amp               = ["read", "write"]
external-network  = false          # Set to a domain list if internet access is needed
# filesystem      = ["read:user-docs"]  # Uncomment if filesystem access is required

[panels]
# main panel — maps to src/panel.tsx (compiled to panels/main.js by the build)
main = { title = "{{appName}}", mount = "panels/main.tsx" }

[agents]
# App-supplied agents follow ADR-011: <app-short-id>_<agent-role>
# File name uses agent-role only (agents/<role>.md), ID uses full prefix.
{{appShortId}}_assistant = "agents/assistant.md"

[skills.exposed]
# Functions this app exposes to other apps (HUB-024 §6.6 Skill API)
# "{{appSlug}}.example_skill" = "skills/example_skill.ts"

[skills.imported]
# Skills this app consumes from other apps
# "pool.search" = ">=0.1"
