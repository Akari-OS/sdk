{
  "name": "@akari-os/schema-panel",
  "version": "0.1.0",
  "description": "Reference React renderer for AKARI Panel Schema v0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "json-logic-js": "^2.0.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/json-logic-js": "^2.0.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ajv": "^8.17.1",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Akari-OS/sdk",
    "directory": "packages/schema-panel"
  },
  "keywords": [
    "akari",
    "akari-os",
    "panel-schema",
    "schema-renderer",
    "mcp",
    "hitl"
