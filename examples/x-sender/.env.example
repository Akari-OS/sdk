# X Sender — required environment variables
# Copy to .env and fill in your values before running.
#
# Obtain credentials from: https://developer.twitter.com/en/portal/dashboard
# Required X Developer App settings:
#   - OAuth 2.0 enabled
#   - App permissions: Read and Write
#   - Callback URI added (must match OAUTH_REDIRECT_URI below)

# X Developer App Client ID (OAuth 2.0)
X_CLIENT_ID=your-x-client-id-here

# X Developer App Client Secret (OAuth 2.0)
X_CLIENT_SECRET=your-x-client-secret-here

# OAuth 2.0 callback URI — must match exactly what you configured in the X Developer Portal
OAUTH_REDIRECT_URI=http://localhost:3000/callback

# (Optional) Override the AKARI goal_ref used in AMP records.
# Defaults to "com.akari.example.x-sender" if not set.
# AKARI_GOAL_REF=your-goal-ref-here
