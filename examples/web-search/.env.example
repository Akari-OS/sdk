# Phase 0: Tavily is the only active provider.
# Get a key at https://tavily.com (free tier available).
TAVILY_API_KEY=

# Provider selection. Phase 0 accepts "tavily" only.
# Switching to "brave" or "exa" currently throws a "Phase 1" error;
# see mcp-server/providers/{brave,exa}.ts for skeletons.
PROVIDER=tavily

