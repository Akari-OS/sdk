{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Akari-OS/m2c/schema/v0.2/capabilities.json",
  "title": "M2C Provider Capabilities",
  "description": "Capabilities announced by an M2C provider at connection time (§6.1). Used by consumers to choose a compatible provider and scope their requests.",
  "type": "object",
  "required": ["protocolVersion", "capabilities"],
  "additionalProperties": false,
  "properties": {
    "protocolVersion": {
      "type": "string",
      "description": "Date-based protocol version (YYYY-MM-DD)",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "capabilities": {
      "type": "object",
      "required": ["modules", "mediaTypes", "precisionLevels"],
      "additionalProperties": false,
      "properties": {
        "modules": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Analysis module names the provider can run (e.g. scene, transcription, visual, color, summary)"
        },
        "mediaTypes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Media types the provider can process. Core: video, image, audio, music, document, presentation, spreadsheet, vector, 3d, archive, data. Custom types use x- prefix."
        },
        "precisionLevels": {
          "type": "array",
          "items": { "type": "string", "enum": ["quick", "standard", "deep"] }
        },
        "maxDuration": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum media duration in seconds the provider accepts (0 = unlimited)"
        },
        "supply": {
          "type": "object",
          "description": "Optional Supply module capabilities (see supply.md)",
          "additionalProperties": false,
          "properties": {
            "contextLevels": {
              "type": "array",
              "items": { "type": "string", "enum": ["L0", "L1", "L2", "L3"] }
            },
            "compression": { "type": "boolean" },
            "isolation": { "type": "boolean" }
          }
        },
        "extensions": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional extension module names beyond the core set"
        }
      }
    }
  }
}
