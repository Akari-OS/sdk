{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Akari-OS/m2c/schema/v0.2/media-context.json",
  "title": "M2C MediaContext v0.2",
  "description": "Structured context extracted from media by M2C analysis pipeline",
  "type": "object",
  "required": ["schemaVersion", "mediaType", "summary", "tags", "confidence", "analyzedModules", "precisionLevel", "analyzedAt"],
  "additionalProperties": true,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "description": "Date-based schema version (YYYY-MM-DD)",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "mediaType": {
      "type": "string",
      "description": "Media type. Core types: video, image, audio, music, document, presentation, spreadsheet, vector, 3d, archive, data. Custom types use x- prefix.",
      "examples": ["video", "image", "audio", "music", "document", "x-figma-design"]
    },
    "summary": {
      "type": "string",
      "description": "AI-generated summary of the media content"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Content tags (AI-generated + user-added)"
    },
    "moods": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Mood/atmosphere labels. See Appendix A for recommended vocabulary."
    },
    "colorPalette": {
      "type": "array",
      "items": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$" },
      "description": "Dominant colors as hex codes"
    },
    "duration": {
      "type": "number",
      "description": "Duration in seconds (0 for non-temporal media)"
    },
    "speakers": {
      "type": "array",
      "items": { "$ref": "#/$defs/SpeakerInfo" }
    },
    "scenes": {
      "type": "array",
      "items": { "$ref": "#/$defs/SceneContext" },
      "description": "Scene-level context (temporal media only)"
    },
    "transcription": {
      "type": "array",
      "items": { "$ref": "#/$defs/TranscriptionSegment" }
    },
    "acoustic": { "$ref": "#/$defs/AcousticContext" },
    "visual": { "$ref": "#/$defs/VisualContext" },
    "extensions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Domain-specific extensions. Use namespaced keys (e.g., 'style.cutTempo', 'brand.guidelines')."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Aggregate confidence score"
    },
    "analyzedModules": {
      "type": "array",
      "items": { "type": "string" },
      "description": "IDs of modules that contributed to this context"
    },
    "precisionLevel": {
      "type": "string",
      "description": "Precision level used for analysis"
    },
    "analyzedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of analysis completion"
    },
    "contextPolicy": { "$ref": "#/$defs/ContextPolicy" }
  },
  "$defs": {
    "SpeakerInfo": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "ratio": { "type": "number", "minimum": 0, "maximum": 1, "description": "Speaking ratio (0-1)" }
      }
    },
    "SceneContext": {
      "type": "object",
      "required": ["index", "start", "end", "summary"],
      "additionalProperties": true,
      "properties": {
        "index": { "type": "integer" },
        "start": { "type": "number", "description": "Start time in seconds" },
        "end": { "type": "number", "description": "End time in seconds" },
        "summary": { "type": "string" },
        "keyframeUri": { "type": "string", "format": "uri", "description": "URI to representative keyframe" },
        "objects": { "type": "array", "items": { "type": "string" } },
        "transcript": { "type": "string" },
        "moods": { "type": "array", "items": { "type": "string" } },
        "colorPalette": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "TranscriptionSegment": {
      "type": "object",
      "required": ["start", "end", "text"],
      "properties": {
        "start": { "type": "number" },
        "end": { "type": "number" },
        "text": { "type": "string" },
        "speaker": { "type": ["string", "null"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "language": { "type": "string", "description": "BCP 47 language tag" }
      }
    },
    "AcousticContext": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "bgmSegments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": { "type": "number" },
              "end": { "type": "number" },
              "mood": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        "silenceSegments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "start": { "type": "number" },
              "end": { "type": "number" }
            }
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "time": { "type": "number" },
              "type": { "type": "string" },
              "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          }
        },
        "hasMusic": { "type": "boolean" },
        "musicRatio": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "VisualContext": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "dominantColors": { "type": "array", "items": { "type": "string" } },
        "averageBrightness": { "type": "number" },
        "faceCount": { "type": "integer" },
        "objectFrequency": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        }
      }
    },
    "ContextPolicy": {
      "type": "object",
      "description": "Isolation and delivery policy for context supply",
      "additionalProperties": true,
      "properties": {
        "audience": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Intended consumers (e.g., 'planner', 'worker', 'user')"
        },
        "temporalScope": {
          "type": "object",
          "properties": {
            "start": { "type": "number" },
            "end": { "type": "number" }
          },
          "description": "Time range this context applies to"
        },
        "modalities": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Which modalities to include (e.g., 'visual', 'transcription', 'acoustic')"
        },
        "priority": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Relative priority for token budget allocation"
        }
      }
    },
    "M2CModuleInput": {
      "type": "object",
      "required": ["mediaUri", "mediaType", "duration"],
      "properties": {
        "mediaUri": { "type": "string", "format": "uri" },
        "mediaType": { "type": "string" },
        "duration": { "type": "number" },
        "options": { "type": "object", "additionalProperties": true },
        "dependencyOutputs": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/M2CModuleOutput" }
        }
      }
    },
    "M2CModuleOutput": {
      "type": "object",
      "required": ["moduleId", "moduleVersion", "durationMs", "confidence", "data"],
      "properties": {
        "moduleId": { "type": "string" },
        "moduleVersion": { "type": "string" },
        "durationMs": { "type": "integer" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "data": {},
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/M2CArtifact" }
        }
      }
    },
    "M2CArtifact": {
      "type": "object",
      "required": ["uri", "mimeType"],
      "properties": {
        "uri": { "type": "string", "format": "uri" },
        "mimeType": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "M2CEstimate": {
      "type": "object",
      "required": ["cost", "costUnit", "timeMs"],
      "properties": {
        "cost": { "type": "number" },
        "costUnit": { "type": "string", "description": "Unit label (e.g., 'credits', 'USD', 'tokens')" },
        "timeMs": { "type": "integer" }
      }
    }
  }
}
